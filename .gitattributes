# Normalize all text files to LF in the repo
* text=auto eol=lf

# Unity specific
*.cs text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.meta text eol=lf
*.controller text eol=lf

# Binaries — never touch line endings
*.png binary
*.jpg binary
*.fbx binary
*.mp3 binary
*.wav binary
*.ogg binary